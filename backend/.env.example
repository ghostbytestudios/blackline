# Copy to .env and adjust. NEVER commit your real .env.

# Where local data lives (SQLite DB, salt). Relative to backend/ by default.
LEDGERLIGHT_DATA_DIR=data

# Server bind — keep this 127.0.0.1. Do NOT change to 0.0.0.0.
LEDGERLIGHT_HOST=127.0.0.1
LEDGERLIGHT_PORT=8000

# Allowed frontend origin (the Vite dev server). Local only.
LEDGERLIGHT_FRONTEND_ORIGIN=http://127.0.0.1:5173

# SimpleFIN Bridge host allowlist (outbound egress is restricted to this host).
LEDGERLIGHT_SIMPLEFIN_ALLOWED_HOST=bridge.simplefin.org

# Argon2id parameters for passphrase-derived key (tune up if your machine is fast).
LEDGERLIGHT_ARGON2_TIME_COST=3
LEDGERLIGHT_ARGON2_MEMORY_KIB=262144
LEDGERLIGHT_ARGON2_PARALLELISM=4
