# Copy to .env and adjust. NEVER commit your real .env.
# All settings are OPTIONAL ??? the defaults below already run securely on localhost.

# Where local data lives (encrypted DB blob + salt). Relative to backend/ by default.
BLACKLINE_DATA_DIR=data

# Server bind ??? keep this 127.0.0.1. Do NOT change to 0.0.0.0 (the app refuses to start).
BLACKLINE_HOST=127.0.0.1
BLACKLINE_PORT=8000

# Allowed frontend origin (the Vite dev server). Local only.
BLACKLINE_FRONTEND_ORIGIN=http://127.0.0.1:5173

# SimpleFIN Bridge host allowlist (outbound egress is restricted to this host).
BLACKLINE_SIMPLEFIN_ALLOWED_HOST=bridge.simplefin.org,beta-bridge.simplefin.org

# Argon2id parameters for the passphrase-derived key (raise if your machine is fast).
BLACKLINE_ARGON2_TIME_COST=3
BLACKLINE_ARGON2_MEMORY_KIB=262144
BLACKLINE_ARGON2_PARALLELISM=4
